# ============================================================
# .gitignore — Webcollect Monorepo (Backend Go + Frontend Next.js)
# ============================================================

# ---- Node / Frontend ----
node_modules/
frontend/node_modules/

# Next.js build artifacts
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# Next.js auto-generated type file (regenerated on build)
frontend/next-env.d.ts

# ---- Go / Backend ----
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test/bench artifacts
*.test
*.out
coverage.txt
coverage.html

# Go vendor (not used here — using modules)
vendor/

# Backend binary output from `go build`
/backend/server
/backend/main.exe

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
backend/.env

# Keep example files
!.env.example
!backend/.env.example
!frontend/.env.example

# ---- Cypress ----
frontend/cypress/screenshots/
frontend/cypress/videos/
frontend/cypress/downloads/
# Large auto-generated output files
frontend/cypress_output.txt
frontend/test_error.log

# ---- TypeScript ----
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker / Local DB ----
pgdata/
